// Project configuration - General settings
ADMIN_EMAILS=your_admin_email_here
CORS_ORIGINS=your_frontend_url_here
JWT_SECRET=your_jwt_secret_here

// MongoDB configuration - Database
DB_NAME=your_database_name_here
MONGO_URL=your_mongodb_connection_string_here

// OpenAI configuration - AI services
OPENAI_API_KEY=your_openai_api_key_here

// Resend configuration - Email service
RESEND_API_KEY=your_resend_api_key_here
SENDER_EMAIL=your_sender_email_here

// Stripe configuration - Payment processing
STRIPE_API_KEY=your_stripe_api_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

// Cloudflare configuration - Image hosting
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_new_token_here
CLOUDFLARE_IMAGES_HASH=your_account_hash_here